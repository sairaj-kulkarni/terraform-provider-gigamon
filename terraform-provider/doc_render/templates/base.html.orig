<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ title }} - My Flask App</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}">
</head>
<body>
    <div class="container">
        <!-- Left Sidebar -->
        <div class="sidebar">
            <h2>Navigation</h2>
            <ul>
                <li><a href="{{ url_for('home') }}">Home</a></li>
			</ul>
			<details>
				<summary> About the home page</summary>
				<div class="indented-content">
				    <ul>
                        <li><a href="{{ url_for('about') }}">About</a></li>
				    </ul>
				</div>
			</details>
			<details>
				<summary> about the contact page</summary>
				<div class="indented-content">
				    <ul>
                      <li><a href="{{ url_for('contact') }}">Contact</a></li>
				    </ul>
				</div>
			</details>
        </div>

        <!-- Right Content Pane -->
        <div class="content" id="right-pane">
            {% block content %}
            <!-- Default content if no block is defined -->
            <h1>Welcome!</h1>
            <p>Select a page from the sidebar.</p>
            {% endblock %}
        </div>
    </div>
	<script src="{{ url_for('static', filename='js/main.js') }}"></script>
</body>
</html>

